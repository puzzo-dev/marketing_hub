[
    {
        "doctype": "Custom Field",
        "name": "Campaign-channels_used",
        "dt": "Campaign",
        "fieldname": "channels_used",
        "label": "Channels",
        "fieldtype": "Small Text",
        "insert_after": "campaign_name",
        "description": "Select channels (comma-separated): Email, WhatsApp, SMS, Push Notification, Google Ads, Meta Ads, TikTok Ads, Twitter/X Ads, Reddit Ads, LinkedIn Ads, Trade Show, TV, Radio, Telecalling, Outdoor, Print, Event, Omni-Channel"
    },
    {
        "doctype": "Custom Field",
        "name": "Campaign-is_omni_campaign",
        "dt": "Campaign",
        "fieldname": "is_omni_campaign",
        "label": "Omni-Channel Campaign",
        "fieldtype": "Check",
        "insert_after": "channels_used"
    },
    {
        "doctype": "Custom Field",
        "name": "Campaign-client",
        "dt": "Campaign",
        "fieldname": "client",
        "label": "Client (Agency Mode)",
        "fieldtype": "Link",
        "options": "Customer",
        "insert_after": "is_omni_campaign"
    },
    {
        "doctype": "Custom Field",
        "name": "Campaign-project",
        "dt": "Campaign",
        "fieldname": "project",
        "label": "Project",
        "fieldtype": "Link",
        "options": "Project",
        "insert_after": "client"
    },
    {
        "doctype": "Custom Field",
        "name": "Campaign-roas",
        "dt": "Campaign",
        "fieldname": "roas",
        "label": "ROAS (Return on Ad Spend)",
        "fieldtype": "Float",
        "precision": "2",
        "insert_after": "project"
    },
    {
        "doctype": "Custom Field",
        "name": "Campaign-budget_section",
        "dt": "Campaign",
        "fieldname": "budget_section",
        "label": "Budget & Tracking",
        "fieldtype": "Section Break",
        "insert_after": "roas",
        "collapsible": 1
    },
    {
        "doctype": "Custom Field",
        "name": "Campaign-budget_amount",
        "dt": "Campaign",
        "fieldname": "budget_amount",
        "label": "Budget Amount",
        "fieldtype": "Currency",
        "insert_after": "budget_section",
        "description": "Total budget allocated for this campaign"
    },
    {
        "doctype": "Custom Field",
        "name": "Campaign-total_spent",
        "dt": "Campaign",
        "fieldname": "total_spent",
        "label": "Total Spent",
        "fieldtype": "Currency",
        "insert_after": "budget_amount",
        "read_only": 1,
        "description": "Total amount spent (auto-calculated from Marketing Expenses)"
    },
    {
        "doctype": "Custom Field",
        "name": "Campaign-column_break_budget",
        "dt": "Campaign",
        "fieldname": "column_break_budget",
        "fieldtype": "Column Break",
        "insert_after": "total_spent"
    },
    {
        "doctype": "Custom Field",
        "name": "Campaign-budget_utilization",
        "dt": "Campaign",
        "fieldname": "budget_utilization",
        "label": "Budget Utilization %",
        "fieldtype": "Percent",
        "insert_after": "column_break_budget",
        "read_only": 1,
        "description": "Percentage of budget spent"
    },
    {
        "doctype": "Custom Field",
        "name": "Campaign-budget_remaining",
        "dt": "Campaign",
        "fieldname": "budget_remaining",
        "label": "Budget Remaining",
        "fieldtype": "Currency",
        "insert_after": "budget_utilization",
        "read_only": 1,
        "description": "Remaining budget amount"
    },
    {
        "doctype": "Custom Field",
        "name": "Lead-utm_campaign",
        "dt": "Lead",
        "fieldname": "utm_campaign",
        "label": "UTM Campaign",
        "fieldtype": "Data",
        "insert_after": "source"
    },
    {
        "doctype": "Custom Field",
        "name": "Lead-utm_source",
        "dt": "Lead",
        "fieldname": "utm_source",
        "label": "UTM Source",
        "fieldtype": "Data",
        "insert_after": "utm_campaign"
    },
    {
        "doctype": "Custom Field",
        "name": "Lead-utm_medium",
        "dt": "Lead",
        "fieldname": "utm_medium",
        "label": "UTM Medium",
        "fieldtype": "Data",
        "insert_after": "utm_source"
    }
]
